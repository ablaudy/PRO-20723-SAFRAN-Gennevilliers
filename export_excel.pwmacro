MACRO INPUT STRING (nomFichierExport, "Nom Fichier Excel Rapport", "Veuillez indiquer le nom du fichier de rapport", "NomRapport" )

DECLARE fichierExport "C:\Users\Antoine\Documents\Customization Project\Projects\PRO-5968 - SAE Genevilliers - Export Resultats  XML\${nomFichierExport}.xlsx"






SYSTEM COMMAND EXEC SYNC ( $vbSaveExcel, {$template, $fichierExport, "Message", "No installation of Microsoft Excel was found on your computer.", "No installation of Microsoft Excel was found on your computer."}  )

MACRO PAUSE ( "Ajout Référence dans Rapport", "Pensez ŕ préciser la référence (case B2) dans le fichier de rapport : ${fichierExport}")


SYSTEM COMMAND EXEC SYNC ( $vbModifsExcel,{$fichierExport, "Corrélation",$txtFile},  )

